{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/dialogs/*": ["./src/components/dialogs/*"],
      "@/layout/*": ["./src/components/layout/*"],
      "@/toolbar/*": ["./src/components/toolbar/*"],
      "@/themed/*": ["./src/components/shadcn/ui/themed/*"],
      "@/icons/*": ["./src/components/icons/*"],
      "@/help/*": ["./src/components/help/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
